#!/usr/bin/env sh

if [ -z "${CODEX_CI-}" ] && [ -z "${CLAUDECODE-}" ] && [ -z "${CURSOR_AGENT-}" ]; then
  exit 0
fi

fail=0
pnpm presubmit || fail=1

if [ "$fail" -ne 0 ]; then
  echo "presubmit failed. Fix with: pnpm format && pnpm lint:fix && pnpm typecheck" >&2
  echo "Or inspect: pnpm presubmit" >&2
  exit 1
fi
